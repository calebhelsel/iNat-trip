# Google Maps API key. Enable BOTH the "Directions API" and the "Maps JavaScript API"
# on this key. This key is used server-side for Directions and is injected into the
# frontend for the Maps JS SDK, so restrict it by HTTP referrer in the Google Cloud console.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
# Contact email/URL sent in the User-Agent header to iNaturalist (be a good citizen).
INAT_CONTACT=you@example.com

# Optional overrides
PORT=5050
# Query-circle radius in km. Larger = fewer circles in sparse areas, but MORE
# discarded observations (and often more requests) in dense areas. See PERFORMANCE.md.
QUERY_RADIUS_KM=5
# Unseen-species filter: "server" (unobserved_by_user_id, fewest requests) or "local".
FILTER_STRATEGY=server
# Concurrent iNaturalist requests. The bottleneck is iNat latency, not the rate
# limiter (still capped ~60/min), so overlapping requests cuts wall-clock time.
INAT_CONCURRENCY=4
# Hard cap on iNat requests per scan — a huge/dense route returns partial results
# with a warning instead of hanging or exhausting the daily quota.
MAX_REQUESTS_PER_SCAN=400
# Hard cap on observations held in memory per scan. Prevents a cross-state route
# from accumulating enough data to OOM a small instance (e.g. Render 512MB free ->
# a 502). Past this the scan stops and returns partial results.
MAX_OBSERVATIONS_PER_SCAN=25000
# Wall-clock cap per scan in seconds. A long/dense route returns partial results
# within this window instead of running until a proxy/browser cuts the connection
# (a 502 or "Unexpected end of JSON input" client-side). Keep under the proxy
# timeout. 0 disables.
SCAN_TIME_BUDGET_SEC=30
# Cache time-to-live in minutes for route->observation scans.
CACHE_TTL_MINUTES=180
# Per-IP rate limit on the public /api/scan endpoint: at most SCAN_RATE_MAX scans
# per SCAN_RATE_WINDOW_MIN minutes. Protects your Google/iNat quota on a public URL.
SCAN_RATE_MAX=20
SCAN_RATE_WINDOW_MIN=10
